# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=
# Mainnet RPC — MUST be an ARCHIVE node (vote proofs call eth_getProof at the
# proposal's snapshot block). Free pruning RPCs reject historical eth_getProof
# and voting will fail. e.g. https://eth-mainnet.g.alchemy.com/v2/<KEY>
NEXT_PUBLIC_MAINNET_RPC_URL=
# Avalanche C-Chain RPC (reads + the vote tx); a normal full node is fine.
NEXT_PUBLIC_AVALANCHE_RPC_URL=
